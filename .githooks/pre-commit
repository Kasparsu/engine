#!/usr/bin/env bash
echo "Running tests before commit..."
if ! bun test; then
  echo "Tests failed — aborting commit."
  exit 1
fi
exit 0
#!/usr/bin/env bash

# Run TypeScript typecheck before committing
echo "Running typecheck..."
if ! bun run typecheck; then
  echo "Typecheck failed. Aborting commit."
  exit 1
fi

exit 0
